{
  "name": "Mira-ai",
  "version": "1.0.0",
  "description": "🕌 Mira Mira AI Backend với multiple free AI providers - Production Ready",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "start:cluster": "CLUSTERING=true node server.js",
    "start:prod": "NODE_ENV=production CLUSTERING=true node server.js",
    "test": "node test.js",
    "test:watch": "nodemon test.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "health": "curl http://localhost:3000/health"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "node-cache": "^5.1.2",
    "node-fetch": "^3.3.2",
    "mongoose": "^8.0.3",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "winston": "^3.11.0",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "joi": "^17.11.0",
    "express-mongo-sanitize": "^2.2.0",
    "@google/generative-ai": "^0.2.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.55.0",
    "prettier": "^3.1.0",
    "@types/node": "^20.10.4",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-node": "^11.1.0"
  },
  "keywords": [
    "islam",
    "ai",
    "Mira",
    "muslim",
    "vietnam",
    "gemini",
    "tensorflow",
    "transformers",
    "production",
    "enterprise",
    "Mira"
  ],
  "author": "Mira Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Mira/Mira-ai-backend.git"
  },
  "homepage": "https://github.com/Mira/Mira-ai-backend#readme",
  "bugs": {
    "url": "https://github.com/Mira/Mira-ai-backend/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Mira"
  },
  "config": {
    "port": 3000,
    "host": "0.0.0.0"
  },
  "nodemonConfig": {
    "watch": [
      "server.js",
      "src/**/*",
      "config/**/*"
    ],
    "ext": "js,json,mjs",
    "ignore": [
      "node_modules/",
      "logs/",
      "test/"
    ],
    "delay": 1000
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverage": true,
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "html"
    ]
  },
  "eslintConfig": {
    "env": {
      "node": true,
      "es2022": true
    },
    "extends": [
      "eslint:recommended",
      "prettier"
    ],
    "parserOptions": {
      "ecmaVersion": "latest",
      "sourceType": "module"
    }
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "printWidth": 80
  }
}